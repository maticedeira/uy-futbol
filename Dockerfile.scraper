FROM node:20

WORKDIR /app

# Install dependencies
COPY apps/scraper/package*.json apps/scraper/
RUN cd apps/scraper && npm install

# Copy project
COPY . .

# Set database URL for WSL/Docker networking
ENV DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5432/postgres"

CMD ["sh", "-c", "cd apps/scraper && npx tsx src/scripts/update-logos.ts"]
